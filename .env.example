# A postgres database url
POSTGRES_URL="postgresql://USERNAME:PASSWORD@HOST/relio?schema=public"

BETTER_AUTH_URL=https://example.net
VERCEL_PROJECT_PRODUCTION_URL=https://example.net
VERCEL_URL=https://example.net
AUTH_SECRET='ENTER_A_SECRET'

# This is actually linked in authetncation credentials, we just didnt change env names.
AUTH_DISCORD_ID='' # Linked in client id
AUTH_DISCORD_SECRET='' # Linked in client secret

# R2 Credentials to upload images and banners
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Elasticsearch (Elastic Cloud)
# Sign up at https://cloud.elastic.co, create a deployment, then:
# 1. Copy the Elasticsearch endpoint URL
# 2. Create an API key from Kibana > Stack Management > API Keys
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
